# Generated by k9x_studio on {{ timestamp }}

app:
  name: "{{ app_name }}"
  folder: "{{ app_folder }}"
  author: "{{ author }}"
  domain: "{{ domain }}"

# ── Inference backend ────────────────────────────────────────────────────────
# Active backend: ollama (local)
# To switch provider: comment out the ollama block below, uncomment the
# openai or grok block, and set the matching key in .env
# ─────────────────────────────────────────────────────────────────────────────

inference:
  llm_factory:

    # ── Ollama (default — local, no API key needed) ───────────────────────
    backend: ollama
    provider: ollama
    base_url: "{{ ollama_base_url }}"
    models:
      general:
        model: "llama3.2:1b"
        temperature: 0.3
        max_tokens: 2048
      reasoning:
        model: "granite3-dense:2b"
        temperature: 0.2
        max_tokens: 4096

    # ── OpenAI (comment out ollama block above and uncomment this) ────────
    # backend: openai
    # api_key: "${OPENAI_API_KEY}"
    # models:
    #   general:
    #     model: "gpt-4o-mini"
    #     temperature: 0.3
    #     max_tokens: 2048
    #   reasoning:
    #     model: "gpt-4o"
    #     temperature: 0.2
    #     max_tokens: 4096

    # ── Grok / xAI (comment out ollama block above and uncomment this) ────
    # backend: openai
    # base_url: "https://api.x.ai/v1"
    # api_key: "${GROK_API_KEY}"
    # models:
    #   general:
    #     model: "grok-3-mini"
    #     temperature: 0.3
    #     max_tokens: 2048
    #   reasoning:
    #     model: "grok-3"
    #     temperature: 0.2
    #     max_tokens: 4096

  router:
    type: k9_model_router
    default_model: general
    persistence:
      enabled: true
      provider: sqlite

  model_catalog:
    default_model: general
    models:
      general:
        provider: ollama
        llm_ref: general
        capabilities: [general, chat, summarization]
        latency_tier: realtime
        cost_tier: minimal
      reasoning:
        provider: ollama
        llm_ref: reasoning
        capabilities: [reasoning, analysis, extraction]
        latency_tier: interactive
        cost_tier: standard

governance:
  enabled: false

monitoring:
  console: true
  log_level: INFO

logging:
  level: DEBUG
