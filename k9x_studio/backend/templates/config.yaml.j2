# Generated by k9x_studio on {{ timestamp }}

app:
  name: "{{ app_name }}"
  folder: "{{ app_folder }}"
  author: "{{ author }}"
  domain: "{{ domain }}"

# ── Inference backend ────────────────────────────────────────────────────────
# K9-AIF supports pluggable LLM providers via ProviderAdapterRegistry.
# Switch provider by editing the llm_factory block below — no code changes needed.
#
# API keys belong in .env (or environment variables), NOT in this file.
# Use api_key_env: MY_ENV_VAR_NAME to reference them safely.
# ─────────────────────────────────────────────────────────────────────────────

inference:
  llm_factory:

    # ── Ollama (default — local, no API key needed) ───────────────────────
    backend: ollama
    provider: ollama
    base_url: "{{ ollama_base_url }}"
    models:
      general:
        model: "llama3.2:1b"
        temperature: 0.3
        max_tokens: 2048
      reasoning:
        model: "granite3-dense:2b"
        temperature: 0.2
        max_tokens: 4096

    # ── OpenAI ───────────────────────────────────────────────────────────
    # To enable: comment out the Ollama block above and uncomment this block.
    # Set OPENAI_API_KEY in your .env file.
    #
    # backend: openai
    # provider: openai
    # api_key_env: OPENAI_API_KEY          # key resolved from environment — never hardcode
    # models:
    #   general:
    #     model: "gpt-4o-mini"
    #     temperature: 0.3
    #     max_tokens: 2048
    #   reasoning:
    #     model: "gpt-4o"
    #     temperature: 0.2
    #     max_tokens: 4096

    # ── Grok / xAI (OpenAI-compatible) ───────────────────────────────────
    # To enable: comment out the Ollama block above and uncomment this block.
    # Set GROK_API_KEY in your .env file.
    #
    # backend: openai-compatible
    # provider: grok
    # base_url: "https://api.x.ai/v1"
    # api_key_env: GROK_API_KEY             # key resolved from environment — never hardcode
    # models:
    #   general:
    #     model: "grok-3-mini"
    #     temperature: 0.3
    #     max_tokens: 2048
    #   reasoning:
    #     model: "grok-3"
    #     temperature: 0.2
    #     max_tokens: 4096

    # ── Custom / future provider ──────────────────────────────────────────
    # Register any BaseProviderAdapter subclass before bootstrap:
    #   ProviderAdapterRegistry.register("myprovider", MyProviderAdapter)
    # Then set backend: myprovider here.

  router:
    type: k9_model_router
    default_model: general
    persistence:
      enabled: true
      provider: sqlite

  model_catalog:
    default_model: general
    models:
      general:
        provider: ollama
        llm_ref: general
        capabilities: [general, chat, summarization]
        latency_tier: realtime
        cost_tier: minimal
      reasoning:
        provider: ollama
        llm_ref: reasoning
        capabilities: [reasoning, analysis, extraction]
        latency_tier: interactive
        cost_tier: standard

governance:
  enabled: false

monitoring:
  console: true
  log_level: INFO

logging:
  level: DEBUG
