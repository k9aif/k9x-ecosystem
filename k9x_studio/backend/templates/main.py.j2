def load_config(path: Path) -> dict:
    with open(path) as f:
        return yaml.safe_load(f)


def render_result_summary(result: dict, app_name: str, orch_name: str, elapsed_s: float, correlation_id: str) -> str:
    lines = []
    status = result.get("status", "unknown").upper()
    squad_id = result.get("squad_id", "—")

    lines.append("=" * _W)
    lines.append("  K9-AIF Execution Summary")
    lines.append("=" * _W)
    lines.append(f"  Project:        {app_name}")
    lines.append(f"  Orchestrator:   {orch_name}")
    lines.append(f"  Status:         {status}")
    lines.append(f"  Squad:          {squad_id}")
    lines.append(f"  Elapsed:        {elapsed_s:.2f}s")
    lines.append(f"  Correlation ID: {correlation_id}")
    lines.append("─" * _W)

    # ── Agent Results table ───────────────────────────────────────────
    skip = {"status", "squad_id"}
    agent_rows = [
        (k, v) for k, v in result.items()
        if k not in skip and isinstance(v, dict)
    ]

    if agent_rows:
        lines.append("")
        lines.append("  Agent Results")
        lines.append("")
        hdr = f"  {'Step':<5}  {'Agent':<28}  {'Status':<12}  {'Conf':>5}  {'Itr':>4}  {'Model'}"
        lines.append(hdr)
        lines.append("  " + "─" * (len(hdr) - 2))

        for step, (key, val) in enumerate(agent_rows, start=1):
            agent_name = val.get("agent", key)
            if len(agent_name) > 26:
                agent_name = agent_name[:23] + "..."

            if "iterations" in val:
                status_cell = val.get("disposition", "—")
                conf = f"{val.get('final_confidence', 0.0):.2f}"
                itr = str(val.get("iterations", "—"))
                model = "—"
            else:
                status_cell = "done"
                conf = "—"
                itr = "—"
                model = val.get("model_used", "—")

            lines.append(
                f"  {step:<5}  {agent_name:<28}  {status_cell:<12}  {conf:>5}  {itr:>4}  {model}"
            )

    # ── Execution Notes ───────────────────────────────────────────────
    lines.append("")
    lines.append("─" * _W)
    lines.append("  Execution Notes")
    lines.append("")

    warnings = []
    for key, val in agent_rows:
        agent_name = val.get("agent", key)
        label = key.replace("_", " ").title()

        if "iterations" in val:
            disp = val.get("disposition", "—")
            conf = val.get("final_confidence", 0.0)
            itr = val.get("iterations", 0)
            evidence = val.get("evidence", [])
            lines.append(f"  [{label}]  Validation Loop · {itr} iteration(s) · disposition={disp} · confidence={conf:.2f}")
            if conf < 0.8:
                warnings.append(f"{agent_name}: confidence {conf:.2f} below threshold 0.80 — implement evaluate_observation() for real domain scoring.")
            lines.append(f"    Evidence: {len(evidence)} observation(s) recorded")
        else:
            output = str(val.get("output", ""))
            snippet = textwrap.shorten(output, width=120, placeholder="…")
            lines.append(f"  [{label}]  {snippet}")

    if warnings:
        lines.append("")
        lines.append("  Warnings")
        for w in warnings:
            lines.append(f"  ⚠  {w}")

    lines.append("")
    lines.append("=" * _W)
    lines.append("  Tip: run with --json to print full result JSON")
    lines.append("=" * _W)
    return "\n".join(lines)


