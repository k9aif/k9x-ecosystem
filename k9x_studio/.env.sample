# k9x_studio — external configuration
# ─────────────────────────────────────────────────────────────
# All external endpoints, API keys, passwords, and secrets go here.
# Copy to .env and fill in your values. Never commit .env to source control.
#
#   cp .env.sample .env
# ─────────────────────────────────────────────────────────────

# ── LLM Backend ───────────────────────────────────────────────
# Supported providers: ollama | openai | anthropic | custom
# Use an IP address or hostname — localhost is blocked on hosted instances.
#
LLM_PROVIDER=ollama
LLM_ENDPOINT=http://192.168.1.10:11434
LLM_MODEL=granite3-dense:2b
LLM_API_KEY=

# OpenAI / OpenAI-compatible (LM Studio, vLLM, Together AI, etc.)
# LLM_PROVIDER=openai
# LLM_ENDPOINT=https://api.openai.com/v1
# LLM_MODEL=gpt-4o-mini
# LLM_API_KEY=sk-...

# Anthropic
# LLM_PROVIDER=anthropic
# LLM_ENDPOINT=https://api.anthropic.com
# LLM_MODEL=claude-haiku-4-5-20251001
# LLM_API_KEY=sk-ant-...

# ── Studio runtime ─────────────────────────────────────────────
# Mounted projects folder inside the container
# K9X_PROJECTS_ROOT=/k9x/projects

# ── Future: additional external integrations ───────────────────
# Database passwords, third-party tokens, etc. go here as the studio grows.
# Example:
# DATABASE_URL=postgresql://user:password@host:5432/db
# SLACK_WEBHOOK_URL=https://hooks.slack.com/...

# Set to 'true' only on public-hosted instances to block localhost LLM endpoints
K9X_BLOCK_LOCAL=false
