# SPDX-License-Identifier: Apache-2.0
# Generated by k9x_studio on {{ timestamp }}
# Agent YAML for {{ agent.name }}

name: {{ agent.name }}
class: {{ agent.name }}

description: >
  {{ agent.description if agent.description else agent.name + ' — update with domain-specific description.' }}

pattern: {{ agent.pattern | default('reasoning') }}
model: {{ agent.model | default('general') }}

role: >
  You are a specialist agent responsible for {{ agent.name | lower | replace('agent', '') | trim }} tasks
  within the {{ domain }} domain.

goal: >
  Execute {{ agent.name | lower | replace('agent', '') | trim }} accurately and return a structured result.

instructions:
  - Analyse the input payload carefully
  - Always include a confidence score in your output
  - Return a structured result matching the output_schema

output_schema:
  agent: string
  output: string
  confidence: float (0.0–1.0)

tools: []
{% if agent.type == 'K9ValidationLoopAgent' %}
max_iterations: 5
confidence_threshold: 0.8
finalize_on_max_iterations: true
{% endif %}

governance:
  pre_process: false
  post_process: false
